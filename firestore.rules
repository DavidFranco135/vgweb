rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Configurações do Admin ───────────────────────────────────
    // O documento 'profile' é lido SEM autenticação para exibir
    // a foto/logo na tela de login (usuário ainda não fez login).
    match /adminSettings/profile {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // Demais documentos de adminSettings: somente admin
    match /adminSettings/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // ── Usuários ─────────────────────────────────────────────────
    // Cada usuário só lê/escreve seu próprio documento.
    // Admins podem ler e escrever todos.
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin');

      allow write: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin');
    }

    // ── Planos ───────────────────────────────────────────────────
    // Leitura pública (aparece na tela de planos sem login).
    // Apenas admins escrevem.
    match /plans/{planId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // ── Anúncios ─────────────────────────────────────────────────
    // Leitura pública (carrossel visível antes do login).
    // Apenas admins escrevem.
    match /announcements/{announcementId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // ── Imagens de Dispositivos ───────────────────────────────────
    // Leitura pública. Apenas admins escrevem.
    match /deviceImages/{deviceId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // ── Faturas ──────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin');
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // ── Chamados ─────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin');
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin');
    }
  }
}
